{
  "name": "m365-user-forensics",
  "version": "1.0.0",
  "description": "Analise de historicidade de usuarios M365 via Microsoft Graph (logins, apps, acessos privilegiados, IPs e geolocalizacao em mapa)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/monitor-query": "^1.3.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "isomorphic-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
