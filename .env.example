# Registro de aplicativo no Entra ID (App Registration)
# Permissoes de API (Application) necessarias, com consentimento de administrador:
#   - AuditLog.Read.All        -> ler sign-in logs
#   - Directory.Read.All       -> resolver usuario e dados de diretorio
#   - RoleManagement.Read.Directory -> ler atribuicoes de roles privilegiadas
#   - User.Read.All            -> ler perfil do usuario

#AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
#AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
#AZURE_CLIENT_SECRET=seu-client-secret-aqui



# Porta do servidor web
PORT=8080

# Numero maximo de eventos de sign-in a buscar (paginacao do Graph)
MAX_SIGNINS=1000
